# JWT_SECRET: (Obrigatório) Chave para assinatura de tokens JWT. 
# Use uma chave longa, aleatória e privada (ex: openssl rand -base64 32).
# No AI Studio, configure em Settings > Secrets.
JWT_SECRET=""

# APP_URL: URL onde o app está hospedado.
APP_URL="MY_APP_URL"

# --- VARIÁVEIS OPCIONAIS ---

# MERCADO_PAGO_ACCESS_TOKEN: Necessário apenas para pagamentos reais.
MERCADO_PAGO_ACCESS_TOKEN=""

# SPOTIFY_CLIENT_ID: Opcional para metadados de trilhas.
SPOTIFY_CLIENT_ID=""

# SPOTIFY_CLIENT_SECRET: Opcional para metadados de trilhas.
SPOTIFY_CLIENT_SECRET=""

# --- SUSPENSO (GOOGLE LOGIN) ---
# O Login via Google está desativado nesta fase do MVP.
